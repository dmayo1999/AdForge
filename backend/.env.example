# AdForge Backend — Environment Variables
# Copy this file to .env.local for local development.
# In production, set these in your Vercel project settings (never commit secrets).

# -------------------------------------------------------------------
# Fal.ai
# -------------------------------------------------------------------
# Your Fal.ai API key. Get one at https://fal.ai/dashboard/keys
FAL_KEY=your_fal_ai_api_key_here

# -------------------------------------------------------------------
# Rate Limiting
# -------------------------------------------------------------------
# Set to "false" to disable rate limiting (useful for local development).
# In production, always leave this as "true".
RATE_LIMIT_ENABLED=true

# -------------------------------------------------------------------
# Upstash Redis (optional — distributed rate limits on Vercel)
# -------------------------------------------------------------------
# Create a Redis database at https://console.upstash.com/ and paste REST credentials.
# If unset, the API uses in-memory rate limiting (single edge instance only).
# If both are set and Redis is unreachable after retries, routes return 503 rate_limit_unavailable.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
